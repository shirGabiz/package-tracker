// Prisma schema for Package Tracker
// Targeting Azure SQL Database (sqlserver provider)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  b2cObjectId  String   @unique
  email        String   @unique
  displayName  String?
  createdAt    DateTime @default(now())

  packages       Package[]
  inboxEntries   InboxEntry[]
}

model Package {
  id             String    @id @default(uuid())
  userId         String
  title          String
  trackingNumber String?
  carrier        String?
  source         PackageSource @default(MANUAL)
  status         PackageStatus @default(PENDING)
  expectedAt     DateTime?
  deliveredAt    DateTime?
  notes          String?   @db.NVarChar(Max)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events  PackageEvent[]
  inbox   InboxEntry[]

  @@index([userId, status])
}

model PackageEvent {
  id          String   @id @default(uuid())
  packageId   String
  eventType   String
  location    String?
  occurredAt  DateTime
  rawPayload  String?  @db.NVarChar(Max)
  createdAt   DateTime @default(now())

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId, occurredAt])
}

model InboxEntry {
  id           String   @id @default(uuid())
  userId       String
  channel      InboxChannel
  rawMessage   String   @db.NVarChar(Max)
  parsedAt     DateTime?
  packageId    String?
  createdAt    DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  package Package? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([userId, channel, createdAt])
}

enum PackageSource {
  MANUAL
  EMAIL
  SMS
  WHATSAPP
}

enum PackageStatus {
  PENDING
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  LOST
  RETURNED
}

enum InboxChannel {
  EMAIL
  SMS
  WHATSAPP
  MANUAL
}
