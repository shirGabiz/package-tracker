{
  "name": "package-tracker",
  "private": true,
  "version": "0.0.0",
  "description": "Personal package tracker - aggregate delivery notifications from email, SMS, WhatsApp and manual entry",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace @package-tracker/api",
    "dev:web": "npm run dev --workspace @package-tracker/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "test:e2e": "playwright test",
    "test:ci": "npm run test && npm run test:e2e"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
